{
  "manifest_version": 3,
  "name": "GitHub Star Manager",
  "version": "1.0.0",
  "description": "轻量化 GitHub 星标仓库管理器 — 分类、搜索、动态追踪、热点推送",
  "permissions": [
    "storage",
    "alarms",
    "sidePanel",
    "notifications"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://translate.googleapis.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://api.github.com https://translate.googleapis.com; style-src 'self' 'unsafe-inline'"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "public/icon16.png",
      "32": "public/icon32.png",
      "48": "public/icon48.png",
      "128": "public/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background/worker.js",
    "type": "module"
  },
  "commands": {
    "open-popup": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "打开 Star Manager"
    },
    "open-sidepanel": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "打开侧边栏"
    },
    "trigger-sync": {
      "suggested_key": {
        "default": "Alt+R",
        "mac": "Alt+R"
      },
      "description": "同步仓库"
    }
  },
  "icons": {
    "16": "public/icon16.png",
    "32": "public/icon32.png",
    "48": "public/icon48.png",
    "128": "public/icon128.png"
  }
}
