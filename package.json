{
  "name": "github-star-manager",
  "version": "1.0.0",
  "description": "轻量化 GitHub 星标仓库管理器 Chrome 插件",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build:ui": "vite build",
    "build:bg": "esbuild src/entrypoints/background/worker.ts --bundle --outfile=dist/background/worker.js --format=esm --target=esnext --platform=browser",
    "build": "npm run build:ui && npm run build:bg && node scripts/copy-files.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "dexie": "^4.0.0",
    "dexie-react-hooks": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/chrome": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "esbuild": "^0.28.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
